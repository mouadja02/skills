                    "shape": "LaunchIdentifier",
                    "location": "uri",
                    "locationName": "launchIdentifier"
                },
                "include": {
                    "shape": "LaunchIncludeSectionList",
                    "documentation": "<p>Sections to include in the response beyond core fields.</p>",
